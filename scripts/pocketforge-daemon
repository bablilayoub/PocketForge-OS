#!/usr/bin/env bash
set -euo pipefail

DEVICE_PROFILE_DIR="${POCKETFORGE_DEVICE_PROFILE_DIR:-/usr/share/pocketforge/device-profiles}"
PERFORMANCE_PROFILE_DIR="${POCKETFORGE_PERFORMANCE_PROFILE_DIR:-/usr/share/pocketforge/performance-profiles}"
REFRESH_INTERVAL="${POCKETFORGE_DAEMON_REFRESH_INTERVAL:-3600}"

log() {
  printf 'pocketforge-daemon: %s\n' "$*"
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

profile_field() {
  local file="$1"
  local field="$2"

  awk -F: -v field="$field" '
    $1 == field {
      value = substr($0, index($0, ":") + 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      gsub(/^"|"$/, "", value)
      print value
      exit
    }
  ' "$file"
}

collect_profiles() {
  local directory="$2"

  if [[ ! -d "$directory" ]]; then
    return
  fi

  local files=()
  while IFS= read -r -d '' file; do
    files+=("$file")
  done < <(find "$directory" -maxdepth 1 -type f -name '*.yml' -print0 | sort -z)

  if [[ "${#files[@]}" -eq 0 ]]; then
    return
  fi

  local file id name
  for file in "${files[@]}"; do
    id="$(profile_field "$file" id)"
    name="$(profile_field "$file" name)"

    if [[ -z "$id" || -z "$name" ]]; then
      continue
    fi

    printf '%s\t%s\n' "$id" "$name"
  done
}

list_profiles() {
  local kind="$1"
  local directory="$2"

  if [[ ! -d "$directory" ]]; then
    log "no ${kind} profile directory found at ${directory}"
    return
  fi

  local found=0
  local id name
  while IFS=$'\t' read -r id name; do
    found=1
    log "${kind} profile loaded: id=${id} name=${name}"
  done < <(collect_profiles "$kind" "$directory")

  if [[ "$found" -eq 0 ]]; then
    log "no complete ${kind} profiles found in ${directory}"
  fi
}

print_profile_array_json() {
  local kind="$1"
  local directory="$2"
  local first=1
  local id name

  printf '"%s_profiles": [' "$kind"
  while IFS=$'\t' read -r id name; do
    if [[ "$first" -eq 0 ]]; then
      printf ', '
    fi
    first=0
    printf '{"id": "%s", "name": "%s"}' "$(json_escape "$id")" "$(json_escape "$name")"
  done < <(collect_profiles "$kind" "$directory")
  printf ']'
}

print_state_json() {
  printf '{'
  print_profile_array_json "device" "$DEVICE_PROFILE_DIR"
  printf ', '
  print_profile_array_json "performance" "$PERFORMANCE_PROFILE_DIR"
  printf '}\n'
}

refresh_state() {
  log "starting metadata refresh"
  list_profiles "device" "$DEVICE_PROFILE_DIR"
  list_profiles "performance" "$PERFORMANCE_PROFILE_DIR"
  log "metadata refresh complete"
}

main() {
  if [[ "${1:-}" == "--help" ]]; then
    echo "Usage: pocketforge-daemon [--once|--json|--help]"
    return
  fi

  if [[ "${1:-}" == "--json" ]]; then
    print_state_json
    return
  fi

  refresh_state

  if [[ "${1:-}" == "--once" ]]; then
    return
  fi

  trap 'log "stopping"; exit 0' INT TERM

  while true; do
    sleep "$REFRESH_INTERVAL" &
    wait "$!"
    refresh_state
  done
}

main "$@"
