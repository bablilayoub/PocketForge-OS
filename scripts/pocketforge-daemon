#!/usr/bin/env bash
set -euo pipefail

DEVICE_PROFILE_DIR="${POCKETFORGE_DEVICE_PROFILE_DIR:-/usr/share/pocketforge/device-profiles}"
PERFORMANCE_PROFILE_DIR="${POCKETFORGE_PERFORMANCE_PROFILE_DIR:-/usr/share/pocketforge/performance-profiles}"
REFRESH_INTERVAL="${POCKETFORGE_DAEMON_REFRESH_INTERVAL:-3600}"
DAEMON_NAME="pocketforge-daemon"
DAEMON_CONTRACT_VERSION="0.2"
DAEMON_MODE="read-only"
DMI_SYS_VENDOR=""
DMI_PRODUCT_NAME=""
DMI_PRODUCT_VERSION=""
DMI_BOARD_NAME=""

log() {
  printf 'pocketforge-daemon: %s\n' "$*"
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

profile_field() {
  local file="$1"
  local field="$2"

  awk -F: -v field="$field" '
    $1 == field {
      value = substr($0, index($0, ":") + 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      gsub(/^"|"$/, "", value)
      print value
      exit
    }
  ' "$file"
}

collect_profiles() {
  local directory="$2"

  if [[ ! -d "$directory" ]]; then
    return
  fi

  local files=()
  while IFS= read -r -d '' file; do
    files+=("$file")
  done < <(find "$directory" -maxdepth 1 -type f -name '*.yml' -print0 | sort -z)

  if [[ "${#files[@]}" -eq 0 ]]; then
    return
  fi

  local file id name
  for file in "${files[@]}"; do
    id="$(profile_field "$file" id)"
    name="$(profile_field "$file" name)"

    if [[ -z "$id" || -z "$name" ]]; then
      continue
    fi

    printf '%s\t%s\n' "$id" "$name"
  done
}

detection_dmi_values() {
  local file="$1"
  local field="$2"

  awk -v field="$field" '
    $0 ~ "^    " field ":[[:space:]]*$" {
      in_field = 1
      next
    }
    in_field && $0 ~ /^      - / {
      value = $0
      sub(/^      -[[:space:]]*/, "", value)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      gsub(/^"|"$/, "", value)
      print value
      next
    }
    in_field && $0 !~ /^      / {
      exit
    }
  ' "$file"
}

read_dmi_value() {
  local field="$1"
  local override=""
  local path=""

  case "$field" in
    sys_vendor)
      override="${POCKETFORGE_DMI_SYS_VENDOR:-}"
      path="/sys/class/dmi/id/sys_vendor"
      ;;
    product_name)
      override="${POCKETFORGE_DMI_PRODUCT_NAME:-}"
      path="/sys/class/dmi/id/product_name"
      ;;
    product_version)
      override="${POCKETFORGE_DMI_PRODUCT_VERSION:-}"
      path="/sys/class/dmi/id/product_version"
      ;;
    board_name)
      override="${POCKETFORGE_DMI_BOARD_NAME:-}"
      path="/sys/class/dmi/id/board_name"
      ;;
  esac

  if [[ -n "$override" ]]; then
    printf '%s' "$override"
    return
  fi

  if [[ -r "$path" ]]; then
    tr -d '\000' < "$path"
  fi
}

matches_any() {
  local value
  value="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  shift

  local pattern
  for pattern in "$@"; do
    pattern="$(printf '%s' "$pattern" | tr '[:upper:]' '[:lower:]')"
    if [[ -n "$pattern" && "$value" == *"$pattern"* ]]; then
      return 0
    fi
  done

  return 1
}

profile_matches_current_dmi() {
  local file="$1"
  local vendor_patterns=()
  local patterns=()

  while IFS= read -r value; do
    vendor_patterns+=("$value")
  done < <(detection_dmi_values "$file" "sys_vendor")

  if [[ "${#vendor_patterns[@]}" -gt 0 ]] && ! matches_any "$DMI_SYS_VENDOR" "${vendor_patterns[@]}"; then
    return 1
  fi

  while IFS= read -r value; do
    patterns+=("$value")
  done < <(detection_dmi_values "$file" "product_name")
  if [[ "${#patterns[@]}" -gt 0 ]] && matches_any "$DMI_PRODUCT_NAME" "${patterns[@]}"; then
    printf '%s' "sys_vendor+product_name"
    return 0
  fi

  patterns=()
  while IFS= read -r value; do
    patterns+=("$value")
  done < <(detection_dmi_values "$file" "product_version")
  if [[ "${#patterns[@]}" -gt 0 ]] && matches_any "$DMI_PRODUCT_VERSION" "${patterns[@]}"; then
    printf '%s' "sys_vendor+product_version"
    return 0
  fi

  patterns=()
  while IFS= read -r value; do
    patterns+=("$value")
  done < <(detection_dmi_values "$file" "board_name")
  if [[ "${#patterns[@]}" -gt 0 ]] && matches_any "$DMI_BOARD_NAME" "${patterns[@]}"; then
    printf '%s' "sys_vendor+board_name"
    return 0
  fi

  return 1
}

load_current_dmi() {
  DMI_SYS_VENDOR="$(read_dmi_value "sys_vendor")"
  DMI_PRODUCT_NAME="$(read_dmi_value "product_name")"
  DMI_PRODUCT_VERSION="$(read_dmi_value "product_version")"
  DMI_BOARD_NAME="$(read_dmi_value "board_name")"
}

detect_current_device() {
  if [[ ! -d "$DEVICE_PROFILE_DIR" ]]; then
    return
  fi

  local files=()
  while IFS= read -r -d '' file; do
    files+=("$file")
  done < <(find "$DEVICE_PROFILE_DIR" -maxdepth 1 -type f -name '*.yml' -print0 | sort -z)

  local file id name matched_on
  for file in "${files[@]}"; do
    if matched_on="$(profile_matches_current_dmi "$file")"; then
      id="$(profile_field "$file" id)"
      name="$(profile_field "$file" name)"
      printf '%s\t%s\t%s\n' "$id" "$name" "$matched_on"
      return
    fi
  done
}

list_profiles() {
  local kind="$1"
  local directory="$2"

  if [[ ! -d "$directory" ]]; then
    log "no ${kind} profile directory found at ${directory}"
    return
  fi

  local found=0
  local id name
  while IFS=$'\t' read -r id name; do
    found=1
    log "${kind} profile loaded: id=${id} name=${name}"
  done < <(collect_profiles "$kind" "$directory")

  if [[ "$found" -eq 0 ]]; then
    log "no complete ${kind} profiles found in ${directory}"
  fi
}

print_profile_array_json() {
  local kind="$1"
  local directory="$2"
  local first=1
  local id name

  printf '"%s_profiles": [' "$kind"
  while IFS=$'\t' read -r id name; do
    if [[ "$first" -eq 0 ]]; then
      printf ', '
    fi
    first=0
    printf '{"id": "%s", "name": "%s"}' "$(json_escape "$id")" "$(json_escape "$name")"
  done < <(collect_profiles "$kind" "$directory")
  printf ']'
}

print_daemon_json() {
  printf '"daemon": {"name": "%s", "contract_version": "%s", "mode": "%s"}' \
    "$(json_escape "$DAEMON_NAME")" \
    "$(json_escape "$DAEMON_CONTRACT_VERSION")" \
    "$(json_escape "$DAEMON_MODE")"
}

print_detection_json() {
  local detected id name matched_on

  load_current_dmi
  detected="$(detect_current_device || true)"

  printf '"detection": {'
  printf '"system": {"sys_vendor": "%s", "product_name": "%s", "product_version": "%s", "board_name": "%s"}, ' \
    "$(json_escape "$DMI_SYS_VENDOR")" \
    "$(json_escape "$DMI_PRODUCT_NAME")" \
    "$(json_escape "$DMI_PRODUCT_VERSION")" \
    "$(json_escape "$DMI_BOARD_NAME")"

  if [[ -n "$detected" ]]; then
    IFS=$'\t' read -r id name matched_on <<< "$detected"
    printf '"current_device": {"matched": true, "id": "%s", "name": "%s", "matched_on": "%s"}' \
      "$(json_escape "$id")" \
      "$(json_escape "$name")" \
      "$(json_escape "$matched_on")"
  else
    printf '"current_device": {"matched": false, "id": "unknown", "name": "Unknown device", "matched_on": "none"}'
  fi

  printf '}'
}

print_state_json() {
  printf '{'
  print_daemon_json
  printf ', '
  print_detection_json
  printf ', '
  print_profile_array_json "device" "$DEVICE_PROFILE_DIR"
  printf ', '
  print_profile_array_json "performance" "$PERFORMANCE_PROFILE_DIR"
  printf '}\n'
}

refresh_state() {
  local detected id name matched_on

  log "starting metadata refresh"
  load_current_dmi
  detected="$(detect_current_device || true)"
  if [[ -n "$detected" ]]; then
    IFS=$'\t' read -r id name matched_on <<< "$detected"
    log "current device matched: id=${id} name=${name} matched_on=${matched_on}"
  else
    log "current device not matched from DMI metadata"
  fi
  list_profiles "device" "$DEVICE_PROFILE_DIR"
  list_profiles "performance" "$PERFORMANCE_PROFILE_DIR"
  log "metadata refresh complete"
}

main() {
  if [[ "${1:-}" == "--help" ]]; then
    echo "Usage: pocketforge-daemon [--once|--json|--help]"
    return
  fi

  if [[ "${1:-}" == "--json" ]]; then
    print_state_json
    return
  fi

  refresh_state

  if [[ "${1:-}" == "--once" ]]; then
    return
  fi

  trap 'log "stopping"; exit 0' INT TERM

  while true; do
    sleep "$REFRESH_INTERVAL" &
    wait "$!"
    refresh_state
  done
}

main "$@"
