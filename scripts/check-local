#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

echo "==> Validating YAML"
ruby -e 'require "yaml"; ARGV.each { |f| YAML.load_stream(File.read(f)); puts "YAML OK: #{f}" }' \
  .github/workflows/build.yml \
  .github/workflows/build-disk.yml \
  .github/workflows/validate.yml \
  .github/dependabot.yml \
  artifacthub-repo.yml \
  shared/device-profiles/*.yml \
  shared/performance-profiles/*.yml

echo "==> Validating JSON"
jq empty \
  files/etc/pocketforge-os/config.json \
  files/usr/share/pocketforge-os/brand.json \
  apps/pocketforge-control-center/sample-inventory.json \
  shared/api/daemon-inventory.schema.json \
  shared/device-profiles/schema.json \
  shared/performance-profiles/schema.json

echo "==> Validating shell scripts"
bash -n build_files/build.sh
bash -n scripts/firstboot.sh
bash -n scripts/pocketforge-daemon
bash -n scripts/check-local
bash -n scripts/image-smoke
bash -n scripts/sync-control-center-sample
bash -n scripts/alpha-status
ruby -c scripts/validate-profiles.rb
ruby -c scripts/validate-daemon-contract.rb
ruby -c scripts/lib/pocketforge/schema_validator.rb

if command -v just >/dev/null 2>&1; then
  echo "==> Validating Justfile"
  just --unstable --fmt --check -f Justfile
fi

echo "==> Checking Control Center prototype files"
test -f apps/pocketforge-control-center/index.html
test -f apps/pocketforge-control-center/app.js
test -f apps/pocketforge-control-center/styles.css
test -f apps/pocketforge-control-center/favicon.svg
test -f files/usr/share/applications/pocketforge-control-center.desktop

echo "==> Validating PocketForge profiles"
ruby scripts/validate-profiles.rb

echo "==> Smoke testing PocketForge daemon"
POCKETFORGE_DEVICE_PROFILE_DIR="$PWD/shared/device-profiles" \
POCKETFORGE_PERFORMANCE_PROFILE_DIR="$PWD/shared/performance-profiles" \
  scripts/pocketforge-daemon --once

POCKETFORGE_DEVICE_PROFILE_DIR="$PWD/shared/device-profiles" \
POCKETFORGE_PERFORMANCE_PROFILE_DIR="$PWD/shared/performance-profiles" \
  scripts/pocketforge-daemon --json | jq empty

echo "==> Testing read-only device detection"
POCKETFORGE_DEVICE_PROFILE_DIR="$PWD/shared/device-profiles" \
POCKETFORGE_PERFORMANCE_PROFILE_DIR="$PWD/shared/performance-profiles" \
POCKETFORGE_DMI_SYS_VENDOR="ASUSTeK COMPUTER INC." \
POCKETFORGE_DMI_PRODUCT_NAME="RC71L" \
  scripts/pocketforge-daemon --json | jq -e '.detection.current_device.id == "rog-ally"' >/dev/null
POCKETFORGE_DEVICE_PROFILE_DIR="$PWD/shared/device-profiles" \
POCKETFORGE_PERFORMANCE_PROFILE_DIR="$PWD/shared/performance-profiles" \
POCKETFORGE_DMI_SYS_VENDOR="ASUSTeK COMPUTER INC." \
POCKETFORGE_DMI_PRODUCT_NAME="RC72LA" \
  scripts/pocketforge-daemon --json | jq -e '.detection.current_device.id == "rog-ally-x"' >/dev/null
POCKETFORGE_DEVICE_PROFILE_DIR="$PWD/shared/device-profiles" \
POCKETFORGE_PERFORMANCE_PROFILE_DIR="$PWD/shared/performance-profiles" \
POCKETFORGE_DMI_SYS_VENDOR="LENOVO" \
POCKETFORGE_DMI_PRODUCT_NAME="83E1" \
POCKETFORGE_DMI_PRODUCT_VERSION="Legion Go 8APU1" \
  scripts/pocketforge-daemon --json | jq -e '.detection.current_device.id == "legion-go"' >/dev/null
POCKETFORGE_DEVICE_PROFILE_DIR="$PWD/shared/device-profiles" \
POCKETFORGE_PERFORMANCE_PROFILE_DIR="$PWD/shared/performance-profiles" \
POCKETFORGE_DMI_SYS_VENDOR="Valve" \
POCKETFORGE_DMI_PRODUCT_NAME="Jupiter" \
  scripts/pocketforge-daemon --json | jq -e '.detection.current_device.id == "steam-deck-lcd"' >/dev/null
POCKETFORGE_DEVICE_PROFILE_DIR="$PWD/shared/device-profiles" \
POCKETFORGE_PERFORMANCE_PROFILE_DIR="$PWD/shared/performance-profiles" \
POCKETFORGE_DMI_SYS_VENDOR="Valve" \
POCKETFORGE_DMI_PRODUCT_NAME="Galileo" \
  scripts/pocketforge-daemon --json | jq -e '.detection.current_device.id == "steam-deck-oled"' >/dev/null
POCKETFORGE_DEVICE_PROFILE_DIR="$PWD/shared/device-profiles" \
POCKETFORGE_PERFORMANCE_PROFILE_DIR="$PWD/shared/performance-profiles" \
POCKETFORGE_DMI_SYS_VENDOR="Unknown Vendor" \
POCKETFORGE_DMI_PRODUCT_NAME="Unknown Product" \
  scripts/pocketforge-daemon --json | jq -e '.detection.current_device.matched == false' >/dev/null

echo "==> Validating PocketForge daemon contract"
ruby scripts/validate-daemon-contract.rb
ruby -rjson -I scripts/lib -rpocketforge/schema_validator -e 'schema = JSON.parse(File.read("shared/api/daemon-inventory.schema.json")); data = JSON.parse(File.read("apps/pocketforge-control-center/sample-inventory.json")); errors = PocketForge::SchemaValidator.validate(data, schema); abort(errors.join("\n")) unless errors.empty?; puts "OK: Control Center sample inventory matches daemon contract"'
scripts/sync-control-center-sample --check
scripts/alpha-status

if command -v rg >/dev/null 2>&1; then
  echo "==> Checking for blocked early-stage references"
  if rg -n "HHD|hhd|image-template|disk_config/iso\\.toml|Handheld OS|handheld-os" . .github -g '!scripts/check-local'; then
    echo "Blocked reference found" >&2
    exit 1
  fi
fi

echo "==> Checking diff whitespace"
git diff --check

echo "All local checks passed."
