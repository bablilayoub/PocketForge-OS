{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pocketforge.dev/schemas/daemon-inventory.json",
  "title": "PocketForge Daemon Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["device_profiles", "performance_profiles"],
  "properties": {
    "device_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "performance_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
