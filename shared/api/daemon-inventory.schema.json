{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pocketforge.dev/schemas/daemon-inventory.json",
  "title": "PocketForge Daemon Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["daemon", "device_profiles", "performance_profiles"],
  "properties": {
    "daemon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "contract_version", "mode"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^pocketforge-daemon$"
        },
        "contract_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "mode": {
          "type": "string",
          "enum": ["read-only"]
        }
      }
    },
    "device_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "performance_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
