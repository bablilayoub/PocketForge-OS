{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pocketforge.dev/schemas/performance-profile.json",
  "title": "PocketForge Performance Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "class", "policy"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "class": {
      "type": "string",
      "enum": ["battery", "balanced", "performance"]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent"],
      "properties": {
        "intent": {
          "type": "string",
          "enum": ["prefer-battery", "balanced", "prefer-performance"]
        }
      }
    }
  }
}
